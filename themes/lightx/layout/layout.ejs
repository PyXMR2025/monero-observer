<%
var pageTitle = page.title || config.subtitle || '';
if (is_archive()) pageTitle = 'Archives';
if (is_tag()) pageTitle = 'Tag: ' + page.tag;
if (is_category()) pageTitle = 'Category: ' + page.category;
if (is_month()) pageTitle += ': ' + page.month + '/' + page.year;
if (is_year()) pageTitle += ': ' + page.year;
pageTitle = config.title + ' | ' + pageTitle;
%>
<!DOCTYPE html>
<html lang="<%=config.language%>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <title><%=pageTitle%></title>
    <meta name="description" content="<%= page.description || config.description || 'Monero news daily publication. Read about the latest Monero research and development efforts, community meetings, events and projects.' %>">
    <!-- <link rel="stylesheet" href="<%= theme.highlight %>"> -->
    <link rel="stylesheet" href="/lightx.css"/>
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icon512.png">
    <meta name="theme-color" content="#ffffff"/>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page.title || config.title %>">
    <meta name="twitter:description" content="<%= page.description || config.description || 'Monero news daily publication. Read about the latest Monero research and development efforts, community meetings, events and projects.' %>">
    <meta name="twitter:image" content="<%= page.thumbnail || 'https://monero-observer.openenet.cn/img/monero-banner.png' %>">
    <!-- <% if(theme.analyticsTrackingID && (theme.analyticsTrackingID.trim() !== "")){%>
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%- theme.analyticsTrackingID.trim() %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', '<%- theme.analyticsTrackingID.trim() %>');
    </script>
    <%}%> -->
  </head>
  <body>
    <!-- <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js', {scope: '/'})
            .then(function (registration) {
              // console.log('ServiceWorker registration successful with scope: ', registration.scope);
            })
            .catch(function (err) {
              console.log('ServiceWorker registration failed: ', err);
            });
        });
      }
    </script> -->
  <div id="page-container">
    <div id="content-wrap">
      <div class="wrapper">
        <div class="container">
            <%-partial('partials/nav')%>
            <%- body %>
        </div>
      </div>
    </div>
    <div id="footer">
      <div class="wrapper">
        <div class="container">
          <%-partial('partials/footer')%>
        </div>
      </div>
    </div>
  </div>
  <!-- <% if(theme.disqus && (theme.disqus.trim() !== "")){%>
    <script id="dsq-count-scr" src="//<%= theme.disqus %>.disqus.com/count.js" async></script>
  <%}%> -->
